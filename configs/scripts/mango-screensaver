#!/bin/bash

# Run the screensaver using random effects from TTE.
# Adapted from Omarchy's screensaver for MangoWM.

screensaver_in_focus() {
  mmsg -g -c 2>/dev/null | grep -q "org.omarchy.screensaver"
}

exit_screensaver() {
  pkill -x tte 2>/dev/null
  pkill -f org.omarchy.screensaver 2>/dev/null
  exit 0
}

trap exit_screensaver SIGINT SIGTERM SIGHUP SIGQUIT

printf '\033]11;rgb:00/00/00\007'

tty=$(tty 2>/dev/null)

sleep 2

while true; do
  tte -i ~/.config/mango/screensaver.txt \
    --frame-rate 120 --canvas-width 0 --canvas-height 0 --reuse-canvas --anchor-canvas c --anchor-text c \
    --random-effect --exclude-effects dev_worm \
    --no-eol --no-restore-cursor &

  while pgrep -t "${tty#/dev/}" -x tte >/dev/null; do
    if read -n1 -t 1 || ! screensaver_in_focus; then
      exit_screensaver
    fi
  done
done
